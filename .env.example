# --- Microsoft 365 credentials (used for first login with MFA) ---
# After first login, the browser session is saved for ~90 days.
MS_USERNAME=usuario@sena.edu.co
MS_PASSWORD=

# --- OneDrive personal (donde los aprendices suben bitácoras) ---
ONEDRIVE_BASE_URL=https://sena4-my.sharepoint.com/personal/lugonzalezs_sena_edu_co
ONEDRIVE_ROOT_FOLDER=/Documents/Instructor Luis Eduardo

# --- SharePoint destino (donde se suben los docs firmados) ---
SHAREPOINT_SITE_URL=https://sena4.sharepoint.com/teams/ETAPASPRODUCTIVAS2025SHP
SHAREPOINT_TARGET_LIBRARY=DOCUMENTOS CERTIFICACIONES 2025/DOCUMENTOS INSTRUCTORES 2025

# --- Base de datos (Excel en SharePoint) ---
DB_EXCEL_URL=https://sena4.sharepoint.com/...ruta-al-excel...

# --- Sesión del navegador ---
SESSION_DIR=config/browser_session

# --- App Config ---
APP_PORT=8000

# --- Firma del instructor ---
SIGNATURE_IMAGE_PATH=config/firma_instructor.png
